{
  "name": "bartnotes",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "migrate:supabase": "node scripts/migrate-to-supabase.mjs",
    "tauri": "tauri",
    "desktop:build:linux": "tauri build && cp -r src-tauri/target/release/bundle/deb/*.deb Linux/ && cp -r src-tauri/target/release/bundle/appimage/*.AppImage Linux/ && cp -r src-tauri/target/release/bundle/rpm/*.rpm Linux/",
    "desktop:build:windows": "tauri build --target x86_64-pc-windows-msvc && cp -r src-tauri/target/x86_64-pc-windows-msvc/release/bundle/nsis/*.exe Windows/"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.0",
    "date-fns": "^3.6.0",
    "lucide-react": "^0.383.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.29.1",
    "react-router-dom": "^6.23.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
